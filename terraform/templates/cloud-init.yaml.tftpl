#cloud-config
hostname: ${hostname}
manage_etc_hosts: true
package_update: true
package_upgrade: true
packages:
  - python3
  - python3-apt
  - python3-pip
  - curl
  - git
  - ca-certificates

runcmd:
  - timedatectl set-timezone UTC || true
  - mkdir -p /opt/hippoject-infra
  - echo "cloud-init bootstrap completed" > /etc/motd
